# 2. Crear tabla de contingencia
tabla <- table(datos$Grupo, datos$Respuesta)
# 3. Ejecutar chi-cuadrado y guardar en objeto 'chi'
chi <- chisq.test(tabla)
# 5. Mostrar solo el valor p
chi$p.value
