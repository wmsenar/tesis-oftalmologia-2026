# Dispersión CCET vs CCT
ggplot(datos, aes(x = CCT, y = CCET, color = Grupo)) +
geom_point(size = 3) +
geom_smooth(method = "lm", se = FALSE) +
labs(title = "Relación entre CCET y CCT",
x = "CCT (micras)",
y = "CCET (micras)") +
theme_minimal()
# ==========================================
# 2. Dispersión CCET vs CCT con línea de regresión
# ==========================================
ggplot(datos, aes(x = CCT, y = CCET, color = Grupo)) +
geom_point(size = 3) +
geom_smooth(method = "lm", se = FALSE, color = "red", linewidth = 1.2) +
labs(title = "Relación entre CCET y CCT",
x = "CCT (micras)",
y = "CCET (micras)") +
theme_minimal()
